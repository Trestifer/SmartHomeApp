<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- Top Bar / Custom Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/menuButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="center"
                android:src="@drawable/ic_menu"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/ink" />

            <TextView
                android:id="@+id/toolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/app_name"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider below Toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_border" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- FrameLayout containing multiple screens toggled by visibility -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 1. HOME SCREEN -->
                <ScrollView
                    android:id="@+id/screenHome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/app_background"
                    android:fillViewport="true"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Device Status Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="18dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/title_device"
                                    android:textColor="@color/ink"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/deviceNameText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="@string/text_no_device"
                                    android:textColor="@color/ink"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/deviceStatusText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/muted"
                                    android:textSize="14sp"
                                    android:lineSpacingMultiplier="1.2" />

                                <TextView
                                    android:id="@+id/offlineWarningText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:textColor="@color/danger"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:visibility="gone" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Square Tiles Grid (Row 1) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <!-- Feed Now Tile -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/tileFeed"
                                android:layout_width="0dp"
                                android:layout_height="130dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/card_border"
                                app:strokeWidth="1dp"
                                android:foreground="?android:attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="🥣"
                                        android:textSize="36sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="@string/title_feed_now"
                                        android:textColor="@color/ink"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Schedules Tile -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/tileSchedules"
                                android:layout_width="0dp"
                                android:layout_height="130dp"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/card_border"
                                app:strokeWidth="1dp"
                                android:foreground="?android:attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📅"
                                        android:textSize="36sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="@string/title_schedules"
                                        android:textColor="@color/ink"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Square Tiles Grid (Row 2) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <!-- Feeding Logs Tile -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/tileFeedingLogs"
                                android:layout_width="0dp"
                                android:layout_height="130dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/card_border"
                                app:strokeWidth="1dp"
                                android:foreground="?android:attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📋"
                                        android:textSize="36sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="@string/title_feeding_history"
                                        android:textColor="@color/ink"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Device Logs Tile -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/tileDeviceLogs"
                                android:layout_width="0dp"
                                android:layout_height="130dp"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                app:cardBackgroundColor="@color/surface"
                                app:cardCornerRadius="16dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/card_border"
                                app:strokeWidth="1dp"
                                android:foreground="?android:attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:orientation="vertical"
                                    android:padding="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="⚙️"
                                        android:textSize="36sp" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="8dp"
                                        android:text="@string/title_device_logs"
                                        android:textColor="@color/ink"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:gravity="center" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Wi-Fi Settings Tile (Full Width Accent) -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tileWifi"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_marginTop="12dp"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp"
                            android:foreground="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="20dp"
                                android:paddingEnd="20dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📶"
                                    android:textSize="28sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="16dp"
                                    android:text="@string/btn_reset_wifi"
                                    android:textColor="@color/ink"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/errorText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:textColor="@color/danger"
                            android:textSize="14sp"
                            android:gravity="center" />
                    </LinearLayout>
                </ScrollView>

                <!-- 2. FEED NOW SCREEN -->
                <ScrollView
                    android:id="@+id/screenFeedNow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/app_background"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🥣"
                            android:textSize="72sp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/title_feed_now"
                                    android:textColor="@color/ink"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <RadioGroup
                                    android:id="@+id/feedPortionGroup"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:orientation="horizontal">

                                    <RadioButton
                                        android:id="@+id/feedSmall"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/portion_small"
                                        android:textColor="@color/ink"
                                        android:buttonTint="@color/primary" />

                                    <RadioButton
                                        android:id="@+id/feedMedium"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="16dp"
                                        android:checked="true"
                                        android:text="@string/portion_medium"
                                        android:textColor="@color/ink"
                                        android:buttonTint="@color/primary" />

                                    <RadioButton
                                        android:id="@+id/feedLarge"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="16dp"
                                        android:text="@string/portion_large"
                                        android:textColor="@color/ink"
                                        android:buttonTint="@color/primary" />
                                </RadioGroup>

                                <Button
                                    android:id="@+id/feedNowButton"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_marginTop="20dp"
                                    android:backgroundTint="@color/primary"
                                    android:text="@string/title_feed_now"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    app:cornerRadius="10dp" />

                                <TextView
                                    android:id="@+id/commandStatusText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:textColor="@color/muted"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </ScrollView>

                <!-- 3. SCHEDULES SCREEN -->
                <ScrollView
                    android:id="@+id/screenSchedules"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/app_background"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/btn_add_schedule"
                                    android:textColor="@color/ink"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <EditText
                                        android:id="@+id/newScheduleTimeInput"
                                        android:layout_width="0dp"
                                        android:layout_height="48dp"
                                        android:layout_weight="1"
                                        android:hint="@string/hint_time"
                                        android:inputType="time"
                                        android:singleLine="true"
                                        android:textColor="@color/ink"
                                        android:textColorHint="@color/muted"
                                        android:backgroundTint="@color/primary" />

                                    <Spinner
                                        android:id="@+id/newSchedulePortionSpinner"
                                        android:layout_width="0dp"
                                        android:layout_height="48dp"
                                        android:layout_marginStart="12dp"
                                        android:layout_weight="1" />
                                </LinearLayout>

                                <Button
                                    android:id="@+id/addScheduleButton"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_marginTop="16dp"
                                    android:backgroundTint="@color/primary"
                                    android:text="@string/btn_add_schedule"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    app:cornerRadius="10dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="@string/title_schedules"
                            android:textColor="@color/ink"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/schedulesContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </ScrollView>

                <!-- 4. FEEDING LOGS SCREEN -->
                <ScrollView
                    android:id="@+id/screenFeedingLogs"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/app_background"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/title_feeding_history"
                            android:textColor="@color/ink"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:id="@+id/feedingLogsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </ScrollView>

                <!-- 5. DEVICE LOGS SCREEN -->
                <ScrollView
                    android:id="@+id/screenDeviceLogs"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/app_background"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/title_device_logs"
                            android:textColor="@color/ink"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:id="@+id/deviceLogsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </ScrollView>

                <!-- 6. WI-FI RESET SCREEN -->
                <ScrollView
                    android:id="@+id/screenWifi"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/app_background"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="72sp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/btn_reset_wifi"
                                    android:textColor="@color/ink"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/wifiWarningText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:textColor="@color/ink"
                                    android:textSize="14sp"
                                    android:lineSpacingMultiplier="1.2" />

                                <Button
                                    android:id="@+id/resetWifiButton"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_marginTop="24dp"
                                    android:backgroundTint="@color/danger"
                                    android:text="@string/btn_reset_wifi"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    app:cornerRadius="10dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </ScrollView>

            </FrameLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <!-- Sidebar Navigation Drawer -->
    <LinearLayout
        android:id="@+id/sidebarDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <!-- Drawer Header with Linear Gradient -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="20dp"
            android:background="@drawable/drawer_header_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/menu_title"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Scrollable Device List -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/devicesListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- Drawer Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/app_background">

            <Button
                android:id="@+id/addDeviceButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/primary"
                android:text="@string/btn_add_device"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="10dp" />

            <TextView
                android:id="@+id/baseUrlText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
